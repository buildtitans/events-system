{
  "name": "infra",
  "version": "0.1.0",
  "bin": {
    "infra": "bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "db:init:remote": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-db-remote.ps1 -Seed",
    "db:migrate:remote": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-db-remote.ps1",
    "release:build": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-release.ps1",
    "release:upload": "powershell -ExecutionPolicy Bypass -File .\\scripts\\upload-release.ps1",
    "release:deploy:remote": "powershell -ExecutionPolicy Bypass -File .\\scripts\\deploy-release-remote.ps1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1100.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.232.1",
    "constructs": "^10.0.0"
  }
}
