{"commands":["echo NEXT_ACTIVE=$(systemctl is-active next || true)","echo NEXT_SHOW_BEGIN","systemctl show next --property=ActiveState,SubState,Result,ExecMainStatus --no-pager","echo NEXT_SHOW_END","echo HOMEPAGE_BEGIN","curl -s http://127.0.0.1:3000 \u003e /tmp/homepage.html \u0026\u0026 wc -c /tmp/homepage.html \u0026\u0026 head -c 1000 /tmp/homepage.html","echo HOMEPAGE_END","echo NEXT_JOURNAL_B64_BEGIN","journalctl -u next -n 200 --no-pager -o cat | base64 -w0","echo","echo NEXT_JOURNAL_B64_END"]}