{"commands":["echo ACTIVE=$(systemctl is-active fastify || true)","echo SHOW_BEGIN","systemctl show fastify --property=ActiveState,SubState,Result,ExecMainStatus --no-pager","echo SHOW_END","echo NEXT_HTTP_BEGIN","curl -s -o /dev/null -w \u0027NEXT:%{http_code}\\n\u0027 http://127.0.0.1:3000","echo FASTIFY_HTTP_BEGIN","curl -s -o /dev/null -w \u0027FASTIFY:%{http_code}\\n\u0027 http://127.0.0.1:3001/api/trpc || true","echo JOURNAL_B64_BEGIN","journalctl -u fastify -n 100 --no-pager -o cat | base64 -w0","echo","echo JOURNAL_B64_END"]}